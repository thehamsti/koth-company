#!/usr/bin/env bash
set -Eeuo pipefail

RUNNER_VERSION="2.335.1"
RUNNER_SHA256="4ef2f25285f0ae4477f1fe1e346db76d2f3ebf03824e2ddd1973a2819bf6c8cf"
RUNNER_ROOT="${RUNNER_ROOT:-$HOME/actions-runner-koth-production}"
RUNNER_NAME="${RUNNER_NAME:-hamsti1-koth-production}"
REPOSITORY_URL="https://github.com/thehamsti/koth-company"
activate_source="${1:-}"
launcher_source="${2:-}"

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

for command in curl flock sha256sum tar; do
  command -v "$command" >/dev/null 2>&1 || die "required command not found: $command"
done
[[ -f "$activate_source" && ! -L "$activate_source" ]] || die "runner activator was not provided"
[[ -f "$launcher_source" && ! -L "$launcher_source" ]] || die "runner launcher was not provided"

umask 077
mkdir -p "$RUNNER_ROOT"
exec 8>"$RUNNER_ROOT/.koth-production-runner-setup.lock"
flock 8
if [[ -f "$RUNNER_ROOT/.runner" ]]; then
  IFS= read -r registration_token || true
  registration_token=""
  bash "$activate_source" "$launcher_source" 8>&-
  printf 'runner already registered and activated at %s\n' "$RUNNER_ROOT"
  exit 0
fi

IFS= read -r registration_token
[[ -n "$registration_token" ]] || die "runner registration token was not provided on standard input"
archive="$RUNNER_ROOT/actions-runner-linux-x64-${RUNNER_VERSION}.tar.gz"
cleanup() {
  rm -f "$archive"
  registration_token=""
}
trap cleanup EXIT

curl \
  --fail \
  --location \
  --proto '=https' \
  --tlsv1.2 \
  --output "$archive" \
  "https://github.com/actions/runner/releases/download/v${RUNNER_VERSION}/actions-runner-linux-x64-${RUNNER_VERSION}.tar.gz"
printf '%s  %s\n' "$RUNNER_SHA256" "$archive" | sha256sum --check --status ||
  die "GitHub Actions runner checksum verification failed"
tar --extract --gzip --file "$archive" --directory "$RUNNER_ROOT"

(
  cd "$RUNNER_ROOT"
  ./config.sh \
    --unattended \
    --url "$REPOSITORY_URL" \
    --token "$registration_token" \
    --name "$RUNNER_NAME" \
    --labels koth-production \
    --work _work \
    --replace
)

bash "$activate_source" "$launcher_source" 8>&-
printf 'runner registered and activated at %s\n' "$RUNNER_ROOT"
