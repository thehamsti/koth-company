#!/usr/bin/env bash
set -Eeuo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=deploy/ops/common.sh
source "$SCRIPT_DIR/common.sh"

release="${1:-}"
market_acceptance="${2:-}"
require_full_sha "$release"
require_layout
require_deployment_bundle "$release"
require_market_acceptance "$market_acceptance"
acquire_lock
ensure_disk_space

current="$(read_release current || true)"
if [[ -n "$current" ]]; then
  require_full_sha "$current"
fi

export KOTH_RELEASE="$release"
compose --profile tools config --quiet
compose --profile tools pull web api migrate gateway cloudflared
compose --profile tools run --rm --no-deps migrate

restore_on_error() {
  local exit_code=$?
  trap - ERR
  printf 'deployment failed; restoring the prior runtime\n' >&2
  if [[ -n "$current" ]]; then
    (start_release "$current") || true
  else
    compose down || true
  fi
  exit "$exit_code"
}
trap restore_on_error ERR

start_release "$release"

if [[ -n "$current" && "$current" != "$release" ]]; then
  write_release previous "$current"
fi
write_release current "$release"
trap - ERR

previous="$(read_release previous || true)"
prune_release_images "$release" "$previous"

printf 'deployed %s\n' "$release"
