# Next.js and Payload CMS
# Application traffic uses PlanetScale's PgBouncer transaction pooler.
DATABASE_URI=postgresql://user:password@host:6432/database?sslmode=verify-full
PAYLOAD_SECRET=replace-with-a-long-random-secret
INTERNAL_API_URL=http://localhost:4000
KOTH_API_REWRITE_URL=http://localhost:4000

# Bun prediction API
PREDICTION_DATABASE_URI=postgresql://prediction_user:password@host:6432/database?sslmode=verify-full
PREDICTION_DATABASE_POOL_SIZE=5
BETTER_AUTH_SECRET=replace-with-a-different-long-random-secret
BETTER_AUTH_URL=http://localhost:3002
TWITCH_CLIENT_ID=replace-with-your-twitch-client-id
TWITCH_CLIENT_SECRET=replace-with-your-twitch-client-secret
TWITCH_BROADCASTER_LOGIN=hydramist
TWITCH_EVENTSUB_SECRET=replace-with-a-random-ascii-string-between-10-and-100-chars
TWITCH_EVENTSUB_CALLBACK_URL=https://your-domain.com/api/twitch/eventsub
TWITCH_HTTP_TIMEOUT_MS=10000
CHANNEL_POINTS_TO_CROWNS_RATE=1000
CHANNEL_POINTS_MAX_PER_USER_PER_EVENT=10000
PREDICTION_INGEST_SECRET=replace-with-a-dedicated-random-secret
PREDICTION_CV_SECRET=replace-with-a-dedicated-random-secret
PREDICTION_MARKETS_ENABLED=false
REALTIME_MAX_SUBSCRIBERS=5000
REALTIME_MAX_CONNECTIONS_PER_IP=20
REALTIME_MAX_LIFETIME_MS=300000
SHUTDOWN_GRACE_MS=10000
API_HOST=0.0.0.0
API_PORT=4000
